# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=moneto
POSTGRES_PASSWORD=         # genera: openssl rand -base64 24
POSTGRES_DB=monetodb

# ── Sicurezza ────────────────────────────────────────────────────────────────
# genera: openssl rand -hex 32
SECRET_KEY=

# ── Token durate ────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REMEMBER_ME_EXPIRE_DAYS=30

# ── CORS (dominio Cloudflare reale) ──────────────────────────────────────────
# Esempio: ["https://moneto.example.com"]
CORS_ORIGINS=["https://tuo-dominio.com"]

# ── Ambiente ─────────────────────────────────────────────────────────────────
APP_ENV=production
