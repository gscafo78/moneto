# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=moneto
POSTGRES_PASSWORD=         # genera: openssl rand -base64 24
POSTGRES_DB=monetodb

# ── Sicurezza ────────────────────────────────────────────────────────────────
# genera: openssl rand -hex 32
SECRET_KEY=

# ── Token durate ────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REMEMBER_ME_EXPIRE_DAYS=30

# ── CORS (dominio Cloudflare reale) ──────────────────────────────────────────
# Esempio: ["https://moneto.example.com"]
CORS_ORIGINS=["https://tuo-dominio.com"]

# ── Ambiente ─────────────────────────────────────────────────────────────────
APP_ENV=production

# Registrazione pubblica: false = solo il primo utente può registrarsi
# Impostare true solo temporaneamente per aggiungere nuovi utenti
# (gestibile anche dall'utente admin in Impostazioni dopo il primo avvio)
ALLOW_REGISTRATION=false

# ── Email (verifica iscrizione, reset password, cambio email) ───────────────
# URL pubblico del frontend, usato nei link delle email
FRONTEND_URL=https://tuo-dominio.com

# Se SMTP_HOST è vuoto, le email vengono solo loggate (nessun invio reale)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Moneto <no-reply@tuo-dominio.com>
SMTP_TLS=true
