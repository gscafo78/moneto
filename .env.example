POSTGRES_USER=budget
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=budgetdb
SECRET_KEY=change_me_with_openssl_rand_hex_32

# Durata access token in minuti (con "Ricordami" viene moltiplicato x48 → 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token senza "Ricordami"
REFRESH_TOKEN_EXPIRE_DAYS=7

# Refresh token con "Ricordami" attivo (default 30 giorni)
REMEMBER_ME_EXPIRE_DAYS=30

CORS_ORIGINS=["http://localhost:5173"]
VITE_API_URL=http://localhost:8000

# ── Email (verifica iscrizione, reset password, cambio email) ───────────────
FRONTEND_URL=http://localhost:5173

# Se SMTP_HOST è vuoto, le email vengono solo loggate (utile in sviluppo)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Moneto <no-reply@moneto.app>
SMTP_TLS=true
